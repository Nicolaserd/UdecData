  proceso_inscripcion      String?
  solicitud_documentos     String?
  respuesta_solicitud      String?
  confianza_servidores     String?
  tiempo_respuesta         String?
  info_canales             String?
  facilidad_acceso         String?
  amabilidad_respeto       String?
  nivel_edificios          String?
  nivel_plataformas        String?
  comentarios              String?
  created_at               DateTime @default(now())

  @@map("satisfaccion_admisiones_registro")
}

