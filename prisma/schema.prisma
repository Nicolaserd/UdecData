generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Estudiante {
  id                Int      @id @default(autoincrement())
  categoria         String
  unidad_regional   String
  nivel             String
  nivel_academico   String
  programa_academico String
  cantidad          Int
  anio              Int      @map("año")
  periodo           String
  created_at        DateTime @default(now())

  @@unique([categoria, unidad_regional, nivel, nivel_academico, programa_academico, anio, periodo])
  @@map("estudiantes")
}

model PlanMejoramientoEstudiante {
  id                       Int      @id @default(autoincrement())
  categoria                String
  subcategoria             String
  plan_de_mejoramiento     String
  actividad                String
  fecha_cumplimiento       String?
  evidencias_cumplimiento  String?
  calificacion_cumplimiento Float?
  efectividad              String?
  programa                 String
  unidad_regional          String
  facultad                 String
  anio                     Int      @map("año")
  encuentro                String
  formulado                String?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  @@unique([encuentro, anio, programa, unidad_regional, facultad, actividad])
  @@map("planes_mejoramiento_estudiantes")
}

model PlanMejoramientoDocente {
  id                       Int      @id @default(autoincrement())
  categoria                String
  subcategoria             String
  plan_de_mejoramiento     String
  actividad                String
  fecha_cumplimiento       String?
  evidencias_cumplimiento  String?
  calificacion_cumplimiento Float?
  programa                 String
  unidad_regional          String
  facultad                 String
  anio                     Int      @map("año")
  encuentro                String
  formulado                String?
  calificacion             String?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  @@unique([encuentro, anio, programa, unidad_regional, facultad, actividad])
  @@map("planes_mejoramiento_docentes")
}

model EncuestaEstudiante {
  id                      Int      @id @default(autoincrement())
  semestre                String?
  experiencia_general     Int?
  profundidad_temas       String?
  retroalimentacion       String?
  seguimiento_compromisos String?
  aspectos_mejora         String?
  programa                String
  anio                    Int      @map("año")
  numero_encuentro        String
  unidad_regional         String
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  @@map("encuestas_estudiantes")
}

model Chat {
  id         Int           @id @default(autoincrement())
  agent_type String
  title      String        @default("Nueva conversación")
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
  messages   ChatMessage[]

  @@map("chats")
}

model ChatMessage {
  id         Int      @id @default(autoincrement())
  chat_id    Int
  role       String
  content    String
  created_at DateTime @default(now())
  chat       Chat     @relation(fields: [chat_id], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model EncuestaDocente {
  id                       Int      @id @default(autoincrement())
  unidad_regional          String
  facultad                 String
  programa                 String?
  encuentro                String
  anio                     Int      @map("año")
  experiencia              Int?
  profundidad_temas        String?
  oportunidad_opinion      String?
  claridad_respuestas      String?
  convocatoria             String?
  organizacion             String?
  mecanismos_participacion String?
  participacion_comunidad  String?
  uso_canales_digitales    String?
  aspectos_mejora          String?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  @@map("encuestas_docentes")
}

model EncuestaSatisfaccion {
  id                  Int      @id @default(autoincrement())
  respuesta_id        Int
  rol                 String
  sede                String
  area                String
  nivel_satisfaccion  String?
  nivel_numerico      Float?
  comentarios         String?
  anio                Int      @map("año")
  periodo_academico   String
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([anio, periodo_academico])
  @@index([sede])
  @@index([area])
  @@map("encuesta_satisfaccion_universidad_cundinamarca")
}

